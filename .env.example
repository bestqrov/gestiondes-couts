# Copy this file to .env for local development (never commit .env itself).
# In production (e.g. Coolify), set these as real platform environment
# variables instead — do not rely on a .env file being present.

# Port the web server listens on. Optional, defaults to 3000 (matches
# Coolify's default "Ports Exposes"). Override locally if 3000 is already in
# use on your machine.
PORT=3000

# Seeds the initial superadmin account on first boot only, i.e. when the
# "users" collection in MongoDB is still empty (see src/web/auth.ts /
# seedSuperAdminIfEmpty). Optional — defaults to redwan / redwan2026 if
# unset. Don't leave the defaults in a publicly reachable deployment;
# additional accounts are created from the superadmin dashboard, not from
# environment variables. Once the account exists, change credentials from
# Réglages > Identifiants, not here — this value is never read again after
# the first successful seed.
SUPERADMIN_USERNAME=redwan
SUPERADMIN_PASSWORD=redwan2026

# MongoDB connection string (see src/db/mongoClient.ts) — required for
# everything that needs to persist: users/app_settings (src/db/
# usersRepository.ts, src/db/appSettingsRepository.ts) and saved
# declaration transactions (superadmin's "Coût de produit"). Unlike a local
# SQLite file, MongoDB Atlas is external to the container, so it survives
# every Coolify redeploy without needing a persistent volume configured.
# Never commit a real value here; set it as a real environment variable in
# Coolify. If a MongoDB Atlas URI's password is ever shared in chat, a
# commit, or any other non-secret channel, treat it as compromised and
# rotate it immediately from the Atlas dashboard.
MONGODB_URI=

# Optional, opt-in image OCR engines (in priority order: OPENAI_API_KEY wins
# if both are set). Both are meaningfully more accurate than the free/local
# Tesseract fallback on dense/tabular printed text (e.g. the Liquidation
# document's tax table), at the cost of a paid API call and a network
# dependency. Leave both unset to use Tesseract only.

# GPT-4o vision — best accuracy for this document's fixed-width ASCII table,
# no dictionary-correction artifacts. Get a key at
# https://platform.openai.com/settings/organization/billing (requires
# funding the account — no free tier) and
# https://platform.openai.com/api-keys.
OPENAI_API_KEY=

# Google Cloud Vision's DOCUMENT_TEXT_DETECTION — used only if
# OPENAI_API_KEY is not set. Get a key at https://console.cloud.google.com/
# (enable "Cloud Vision API", then APIs & Services > Credentials > Create
# Credentials > API Key; has a small free tier but still requires billing
# to be enabled on the project).
GOOGLE_VISION_API_KEY=

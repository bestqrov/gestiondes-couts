# Copy this file to .env for local development (never commit .env itself).
# In production (e.g. Coolify), set these as real platform environment
# variables instead — do not rely on a .env file being present.

# Port the web server listens on. Optional, defaults to 4310.
PORT=4310

# Login gate credentials (see src/web/auth.ts). Optional — defaults to
# redwan / redwan2026 if unset. This is an access gate, not real security;
# still, don't leave the defaults in a publicly reachable deployment.
APP_USERNAME=redwan
APP_PASSWORD=redwan2026

# Optional. If set, image uploads (screenshots/photos, not PDFs) are OCR'd
# via Google Cloud Vision's DOCUMENT_TEXT_DETECTION instead of the local,
# free Tesseract engine — meaningfully more accurate on dense/tabular text,
# at the cost of a paid API call (small free tier) and a network dependency.
# Leave unset to use Tesseract only. Get a key at
# https://console.cloud.google.com/ (enable "Cloud Vision API", then
# APIs & Services > Credentials > Create Credentials > API Key).
GOOGLE_VISION_API_KEY=
